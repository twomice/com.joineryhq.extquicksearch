<?xml version="1.0"?>
<extension key="com.joineryhq.extquicksearch" type="module">
  <file>extquicksearch</file>
  <name>Extended Quick Search</name>
  <description>Extends Quick Search to include a configurable collection of custom fields.</description>
  <license>GPL-3.0</license>
  <maintainer>
    <author>Allen Shaw</author>
    <email>allen@joineryhq.com</email>
  </maintainer>
  <urls>
    <url desc="Main Extension Page">https://github.com/twomice/com.joineryhq.extquicksearch</url>
    <url desc="Documentation">https://github.com/twomice/com.joineryhq.extquicksearch</url>
    <url desc="Support">https://github.com/twomice/com.joineryhq.extquicksearch/issues</url>
    <url desc="Licensing">http://www.gnu.org/licenses/gpl-3.0.html</url>
  </urls>
  <releaseDate>2021-12-06</releaseDate>
  <version>0.3.1</version>
  <develStage>beta</develStage>
  <compatibility>
    <ver>5.51</ver>
  </compatibility>
  <comments/>
  <civix>
    <namespace>CRM/Extquicksearch</namespace>
    <format>25.10.2</format>
  </civix>
  <mixins>
    <mixin>mgd-php@2.0.0</mixin>
    <mixin>setting-php@1.0.0</mixin>
    <mixin>scan-classes@1.0.0</mixin>
  </mixins>
  <classloader>
    <psr0 prefix="CRM_" path="."/>
    <psr4 prefix="Civi\" path="Civi"/>
  </classloader>
</extension>
